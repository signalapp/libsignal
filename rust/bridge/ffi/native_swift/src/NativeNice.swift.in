        let ({{ field }}_ffi, {{ field }}_keepalive): (
            {{ ty.converter_type }}.FfiArg,
            {{ ty.converter_type }}.KeepAlive?,
        ) = {{ ty.converter_type }}.convertArg({{ field }})
    {% endfor %}
    let ffiStructArg = {{ constructor }}(
            {%- for (field, ty) in struct.fields -%}
                {{ field|to_snake_case }}: {{field}}_ffi,
            {%- endfor -%}
        )
    let ffiStructKeepAlive: (
        {%- for (field, ty) in struct.fields %}{{ty.converter_type}}.KeepAlive?,{% endfor -%}
    )? =
        (
            {%- for (field, ty) in struct.fields %} {{ field }}_keepalive != nil || {% endfor -%} false
        ) ? (
            {%- for (field, ty) in struct.fields %} {{ field }}_keepalive, {% endfor -%}
        ) : nil
{% endmacro %}

