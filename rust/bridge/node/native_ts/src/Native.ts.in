{% macro simple_struct_fields(struct) %}
    {%- for (field, converter) in struct.fields -%}
        {{ field }}: {{ converter.ffi_type }};
    {%- endfor -%}
{% endmacro %}
{% for (name, struct_or_enum) in ctx.derived_return_converters|items -%}
    {% if struct_or_enum.kind == "Struct" %}
        {% set struct = struct_or_enum %}
        export type {{ name | return_ffi_type }} = {
            {{ simple_struct_fields(struct) }}
        };
    {% else %}
        {% set enum = struct_or_enum %}
        export type {{ name | return_ffi_type }} = {%- for (variant, struct) in enum.variants -%}
            | {
                __type: {{ loop.index0 }};
                {{ simple_struct_fields(struct) }}
            }
        {%- endfor -%};
    {% endif %}
{%- endfor %}
{% for (name, struct_or_enum) in ctx.derived_arg_converters|items -%}
    {% if struct_or_enum.kind == "Struct" %}
        {% set struct = struct_or_enum %}
        export type {{ name | arg_ffi_type }} = {
            {{ simple_struct_fields(struct) }}
        };
    {% else %}
        {% set enum = struct_or_enum %}
        export type {{ name | arg_ffi_type }} = {%- for (variant, struct) in enum.variants -%}
            | {
                __type: {{ loop.index0 }};
                {{ simple_struct_fields(struct) }}
            }
        {%- endfor -%};
    {% endif %}
{%- endfor %}

