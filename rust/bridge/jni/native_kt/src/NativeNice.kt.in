{% set ctx = testing_ctx if testing else non_testing_ctx %}

{% macro struct_class(name, struct, arg_converter, return_converter, superclass) %}
    {%- if struct.fields|count == 0 -%}
        internal data object {{ name }}{% if superclass %}: {{ superclass }}(){% endif %} {
            {% if return_converter %}
                @JvmStatic
                @CalledFromNative
                fun fromNative(): {{ name }} = {{ name }}
            {% endif %}
            {% if arg_converter %}
                @CalledFromNative
                internal object FfiArgType{% if superclass %}: {{ superclass }}.FfiArgType(){% endif %}
                {% if superclass %}override {% endif %}fun toFfiArgType(): FfiArgType = FfiArgType
            {% endif %}
        }
    {%- else -%}
        internal data class {{ name }}(
            {% for (field, ty) in struct.fields -%}
                val {{ field|to_lower_camel_case }}: {{ ty }},
            {%- endfor %}
        ){% if superclass %}: {{ superclass }}(){% endif %} {
            {% if return_converter is defined %}
                companion object {
                    @JvmStatic
                    @CalledFromNative
                    fun fromNative(
                        {%- for (field, ty) in return_converter.fields -%}{{ field }}: Any?,{%- endfor -%}
                    ): {{ name }} = {{ name }}(
                        {%- for (field, ty) in return_converter.fields -%}
                            {{ field|to_lower_camel_case }} =
                                {{ ty.converter_function }}({{ field }} as {{ ty.ffi_type }}),
                        {%- endfor -%}
                    )
                }
            {% endif %}
            {% if arg_converter is defined %}
                @CalledFromNative
                @Suppress("ktlint:standard:backing-property-naming")
                internal class FfiArgType{% if superclass %}: {{ superclass }}.FfiArgType{% endif %} {
                    {% for (field, ty) in arg_converter.fields %}
                        @CalledFromNative
                        internal val {{ field }}: {{ ty.ffi_field_type_erased }}
                    {%- endfor %}
                    constructor(
                        {% for (field, ty) in arg_converter.fields -%}
                            {{ field }}: {{ ty.ffi_field_type_erased }},
                        {%- endfor %}
                    ) {
                        {%- for (field, ty) in arg_converter.fields %}
                            this.{{ field }} = {{ field }}
                        {%- endfor %}
                    }
                }
                {% if superclass %}override {% endif %}fun toFfiArgType(): FfiArgType = FfiArgType(
                    {% for (field, ty) in arg_converter.fields -%}
                        {{ field }} = {{ ty.converter_function }}({{ field|to_lower_camel_case }}),
                    {%- endfor %}
                )
            {% endif %}
        }
    {%- endif -%}
{% endmacro %}

{% for (name, struct_or_enum) in ctx.derived_types|items %}
    {% if struct_or_enum.kind == "Struct" %}
        {{ struct_class(
            name,
            struct_or_enum,
            arg_converter=ctx.derived_arg_converters[name],
            return_converter=ctx.derived_return_converters[name],
            superclass=none,
        ) }}
    {% else %}
        internal sealed class {{ name }} {
            {% for (variant, struct) in struct_or_enum.variants -%}
                {{ struct_class(
                    variant,
                    struct,
                    arg_converter=(ctx.derived_arg_converters[name].variants[loop.index0][1]
                        if ctx.derived_arg_converters[name] is defined),
                    return_converter=(ctx.derived_return_converters[name].variants[loop.index0][1]
                        if ctx.derived_return_converters[name] is defined),
                    superclass=name,
                ) }}
            {%- endfor %}
            {% if ctx.derived_arg_converters[name] is defined %}
                internal sealed class FfiArgType
                internal abstract fun toFfiArgType(): FfiArgType
            {% endif %}
        }
    {% endif %}
    {% if ctx.derived_arg_converters[name] is defined %}
        internal fun {{ name }}.toFfiArgTypeObject(): Object = convertToObject(this.toFfiArgType())
    {% endif %}
{% endfor %}

internal object {{ "NativeTestingNice" if testing else "NativeNice" }} {
    {% for (name, f) in ctx.nice_functions|items %}
        public fun {{ name }}(
            {% if f.is_tokio_async -%}
                asyncCtx: TokioAsyncContext,
            {% endif -%}
            {% for (arg, ty) in f.arguments -%}
                {{ arg|to_lower_camel_case }}: {{ ty.nice_type }},
            {% endfor -%}
        ): {% if f.is_tokio_async -%}
            CompletableFuture<{{ f.return_type.nice_type }}>
        {%- else -%}
            {{ f.return_type.nice_type }}
        {%- endif %} {
            {% for (arg, ty) in f.arguments -%}
                val ffi_{{ arg }} = {{ ty.converter_function }}({{ arg|to_lower_camel_case }})
            {% endfor -%}
            val ffiOut = {% if f.is_tokio_async %} NativeHandleGuard(asyncCtx).use { asyncCtxHandle -> {% endif %}
                Native{% if testing %}Testing{% endif %}.{{ name }}(
                    {%- if f.is_tokio_async -%}
                        asyncCtxHandle.nativeHandle(),
                    {%- endif %}
                    {% for (arg, ty) in f.arguments -%}
                        ffi_{{ arg }},
                    {% endfor -%}
                )
            {% if f.is_tokio_async %} } {% endif %}
            {% if f.is_tokio_async -%}
                return ffiOut
                  .makeCancelable(asyncCtx)
                  {% if f.return_type.converter_function != "identity" -%}
                  .thenApply { {{ f.return_type.converter_function }}(it) }
                  {%- endif %}
            {%- else -%}
                return {{ f.return_type.converter_function }}(ffiOut)
            {%- endif %}
        }
    {% endfor %}
}
